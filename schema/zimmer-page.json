      {
        "@type": "Question",
        "name": "Ab wie vielen Nächten kann man ein Zimmer buchen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Unsere Gästezimmer sind ab 2 Nächten buchbar."
        }
      },
      {
        "@type": "Question",
        "name": "Gibt es Frühstück im Sonnenhof?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Wir bieten eine Teeküche im 1. Stock mit Kaffee, Tee und Grundausstattung. Frühstücksmöglichkeiten gibt es in den umliegenden Cafés und Bäckereien."
        }
      },
      {
        "@type": "Question",
        "name": "Haben die Zimmer ein eigenes Bad?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, alle Gästezimmer verfügen über ein eigenes Badezimmer mit Dusche."
        }
      },
      {
        "@type": "Question",
        "name": "Wie oft werden die Zimmer gereinigt?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Zimmer werden alle drei Tage gereinigt. Bettwäsche und Handtücher werden dabei gewechselt."
        }
      },
      {
        "@type": "Question",
        "name": "Kann man auch als Geschäftsreisender buchen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, unsere Einzelzimmer und Doppelzimmer eignen sich ideal für Geschäftsreisende. Kostenfreies WLAN ist in allen Zimmern verfügbar."
        }
